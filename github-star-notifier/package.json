{
  "name": "github-star-notifier",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node ../scripts/run-module-runner.mjs main.ts",
    "check": "pnpm --dir .. run check",
    "check:fix": "pnpm --dir .. run check:fix",
    "test": "pnpm --dir .. exec vp test run --project github-star-notifier",
    "typecheck": "pnpm --dir .. exec tsc --noEmit -p github-star-notifier/tsconfig.json"
  },
  "dependencies": {
    "@atproto/api": "^0.20.22",
    "@google/genai": "^2.10.0",
    "@mozilla/readability": "^0.6.0",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "open-graph-scraper": "^6.12.0",
    "rss-parser": "^3.13.0",
    "sharp": "^0.35.2"
  }
}
