{
  "name": "github-actions-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "vp check",
    "check:fix": "vp check --fix",
    "test": "vp test",
    "test:github-star-notifier": "vp test --project github-star-notifier",
    "test:rss-feed-notifier": "vp test --project rss-feed-notifier",
    "typecheck": "tsc --noEmit -p github-star-notifier/tsconfig.json && tsc --noEmit -p rss-feed-notifier/tsconfig.json && tsc --noEmit -p link-insight-notifier/tsconfig.json"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.0.1",
    "@voidzero-dev/vite-plus-core": "0.2.1",
    "typescript": "7.0.1-rc",
    "vite-plus": "^0.2.1",
    "vitest": "4.1.9"
  },
  "packageManager": "pnpm@11.9.0"
}
